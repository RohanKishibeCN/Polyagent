{
  "name": "polyagent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --import tsx --experimental-websocket src/index.ts",
    "dev": "node --import tsx --experimental-websocket src/index.ts --strategy simulation --rounds 10",
    "prod": "node --import tsx --experimental-websocket src/index.ts --prod",
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@ethersproject/wallet": "^5.8.0",
    "@js-sdsl/ordered-map": "^4.4.2",
    "@polymarket/builder-relayer-client": "^0.0.8",
    "@polymarket/clob-client-v2": "^1.0.2",
    "commander": "^14.0.3",
    "dotenv": "^16.4.0",
    "ethers": "^6",
    "tsx": "^4.0.0",
    "ws": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.1",
    "@types/ws": "^8.18.1",
    "prettier": "^3.8.1",
    "sinon": "^21.1.2",
    "typescript": "^5.0.0"
  }
}
